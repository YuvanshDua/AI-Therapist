# Copy to backend/.env and adjust paths for your machine.

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Ollama (local LLM)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_ENABLED=True
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.6
OLLAMA_NUM_PREDICT=140

# -----------------------------------------------------------------------------
# Whisper / STT
# Choose one:
#   WHISPER_ENGINE=faster_whisper
#   WHISPER_ENGINE=whisper_cpp
# -----------------------------------------------------------------------------
WHISPER_ENGINE=faster_whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# If WHISPER_ENGINE=whisper_cpp
WHISPER_CPP_BIN=whisper-cli
WHISPER_CPP_MODEL_PATH=/absolute/path/to/ggml-base.en.bin
FFMPEG_BIN=ffmpeg

# -----------------------------------------------------------------------------
# TTS
# Choose one:
#   TTS_ENGINE=piper
#   TTS_ENGINE=coqui
#   TTS_ENGINE=edge_tts
# -----------------------------------------------------------------------------
TTS_ENGINE=piper
PIPER_BIN=piper
PIPER_MODEL_PATH=/absolute/path/to/en_US-lessac-medium.onnx
COQUI_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_RATE=-2%
EDGE_TTS_PITCH=+0Hz
EDGE_TTS_VOLUME=+0%
TTS_PIPER_LENGTH_SCALE=1.08
TTS_PIPER_NOISE_SCALE=0.6
TTS_PIPER_NOISE_W_SCALE=0.9
TTS_PIPER_SENTENCE_SILENCE=0.26
TTS_PIPER_VOLUME=1.0
TTS_MAX_INPUT_CHARS=800

# -----------------------------------------------------------------------------
# Therapy memory/safety behavior
# -----------------------------------------------------------------------------
THERAPY_RECENT_MESSAGE_LIMIT=8
THERAPY_SUMMARY_INTERVAL=6
THERAPY_SUMMARY_MAX_CHARS=1200
THERAPY_CRISIS_HOTLINE=988 (US & Canada)

# -----------------------------------------------------------------------------
# Optional production channels backend
# -----------------------------------------------------------------------------
# CHANNEL_REDIS_URL=redis://localhost:6379/0
